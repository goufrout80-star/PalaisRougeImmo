# ============================================
# PALAIS ROUGE IMMO — ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env.local and fill in your real values:
#   cp .env.example .env.local
#
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# All others are server-side only (API routes, server components).
# ============================================

# ── APP ──────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Palais Rouge Immo
NEXT_PUBLIC_COMPANY_EMAIL=contact@palaisrouge.online
NEXT_PUBLIC_COMPANY_PHONE=+212524430000

# ── SUPABASE ─────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── EMAIL (Resend — recommended for Next.js) ─
RESEND_API_KEY=re_your_resend_api_key_here
EMAIL_FROM=noreply@palaisrouge.online
EMAIL_TO=contact@palaisrouge.online

# ── IMAGE UPLOAD (Cloudinary) ────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── GOOGLE MAPS ──────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ── GOOGLE ANALYTICS ─────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ── STRIPE (payments / deposits) ─────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ── SENTRY (error tracking) ─────────────────
NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# ── FEATURE FLAGS ────────────────────────────
NEXT_PUBLIC_ENABLE_PAYMENTS=false
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_MAPS=true
NEXT_PUBLIC_ENABLE_IMAGE_UPLOAD=true
