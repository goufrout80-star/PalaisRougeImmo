# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# supabase local
supabase/.branches/
supabase/.temp/

# editor files
.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# local temp folders
uploads/
tmp/

# OS files
Thumbs.db
*.swp

# Raw SQL dumps — never commit these
supabase/migrations/12sqls.sql
12sqls.sql
*sqls.sql
supabase/migrations/[^2]*.sql
